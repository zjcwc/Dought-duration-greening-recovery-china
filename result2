# rolling-window lag-1 TAC through time. Positive values indicate increasing TAC.
TAC_TREND_PATH <- file.path(DATA_DIR, "tac", "tac_trend.tif")

# Vegetation-state products
VEG_MEAN_PATH  <- file.path(DATA_DIR, "vegetation", "mean_kNDVI.tif")
VEG_SLOPE_PATH <- file.path(DATA_DIR, "vegetation", "kNDVI_trend.tif")

# Background climate controls
CLIMATE_PATHS <- list(
  mean_temperature = file.path(DATA_DIR, "climate", "mean_temperature.tif"),
  vapor_pressure_deficit = file.path(DATA_DIR, "climate", "vpd.tif"),
  precipitation_seasonality = file.path(DATA_DIR, "climate", "precipitation_seasonality.tif"),
  precipitation_variability = file.path(DATA_DIR, "climate", "precipitation_variability.tif")
