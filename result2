DROUGHT_BAND_NAMES <- c(
  "Total_Drought_Count",
  "SUB_Severity",
  "SUB_Duration"
)

# Analysis settings
K_SMOOTH <- 6
SPATIAL_K <- 80
CONTRAST_QUANTILES <- c(0.10, 0.90)

# Set TRUE for a lighter public demonstration. For full analysis, use FALSE.
RUN_SPATIAL_BLOCK_CV <- FALSE
SPATIAL_K_FOLDS <- 5
