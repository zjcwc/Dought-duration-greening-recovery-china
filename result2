# 1. User settings
# ------------------------------------------------------------

# Main directories
DATA_DIR <- "data"
OUTPUT_ROOT <- "outputs/drought_traits_TAC_state_dependence"

dir.create(OUTPUT_ROOT, recursive = TRUE, showWarnings = FALSE)

# Core raster inputs
